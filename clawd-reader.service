[Unit]
Description=Clawd Reader
After=network.target

[Service]
Type=simple
User=andrepaim
Group=andrepaim
WorkingDirectory=/root/clawd-reader/backend
EnvironmentFile=/root/clawd-reader/backend/.env
ExecStart=/usr/bin/python3 -m uvicorn main:app --host 0.0.0.0 --port 8200
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
