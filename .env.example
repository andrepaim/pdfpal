# Required for AI chat — path to the claude CLI binary
CLAUDE_BIN=/usr/local/bin/claude

# Required for web search augmentation
TAVILY_API_KEY=

# Google OAuth (leave empty to disable auth for local/solo use)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ALLOWED_EMAILS=
SESSION_SECRET=change-me
PUBLIC_URL=http://localhost:8200

# Database path (default: backend/pdfpal.db)
# PDFPAL_DB=./pdfpal.db

# CORS origins (comma-separated, default: * for local dev)
# CORS_ORIGINS=*
